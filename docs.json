{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Doofinder API Reference",
  "colors": {
    "primary": "#4842C1",
    "light": "#6B5FD0",
    "dark": "#1B1851"
  },
  "custom": {
    "css": "/custom.css"
  },
  "favicon": "/favicon.ico",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Admin Panel",
        "href": "https://admin.doofinder.com"
      },
      {
        "label": "Support",
        "href": "https://support.doofinder.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started Free",
      "href": "https://admin.doofinder.com/auth/signup"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt",
      "perplexity",
      "cursor",
      "vscode",
      "mcp"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/doofinder",
      "github": "https://github.com/doofinder",
      "linkedin": "https://www.linkedin.com/company/doofinder"
    }
  },
  "redirects": [
    {
      "source": "/api/search/v6",
      "destination": "/search-api/overview"
    },
    {
      "source": "/api/search/v6/",
      "destination": "/search-api/overview"
    },
    {
      "source": "/api/search/v5",
      "destination": "/search-api/overview"
    },
    {
      "source": "/api/search/v5/",
      "destination": "/search-api/overview"
    },
    {
      "source": "/api/management/v2",
      "destination": "/management-api/overview"
    },
    {
      "source": "/api/management/v2/",
      "destination": "/management-api/overview"
    },
    {
      "source": "/api/stats/v2",
      "destination": "/stats-api/overview"
    },
    {
      "source": "/api/stats/v2/",
      "destination": "/stats-api/overview"
    },
    {
      "source": "/api/management/v2/stats",
      "destination": "/stats-api/overview"
    },
    {
      "source": "/api/management/v2/stats/",
      "destination": "/stats-api/overview"
    },
    {
      "source": "/api/recommendations",
      "destination": "/recommendations-api/overview"
    },
    {
      "source": "/api/recommendations/",
      "destination": "/recommendations-api/overview"
    },
    {
      "source": "/api/category-merchandising",
      "destination": "/category-merchandising/overview"
    },
    {
      "source": "/api/category-merchandising/",
      "destination": "/category-merchandising/overview"
    }
