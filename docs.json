{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Doofinder API Reference",
  "colors": {
    "primary": "#4842C1",
    "light": "#6B5FD0",
    "dark": "#1B1851"
  },
  "custom": {
    "css": "/custom.css"
  },
  "favicon": "/favicon.ico",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Admin Panel",
        "href": "https://admin.doofinder.com"
      },
      {
        "label": "Support",
        "href": "https://support.doofinder.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started Free",
      "href": "https://admin.doofinder.com/auth/signup"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt",
      "perplexity",
      "cursor",
      "vscode",
      "mcp"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/doofinder",
      "github": "https://github.com/doofinder",
      "linkedin": "https://www.linkedin.com/company/doofinder"
    }
  },
  "redirects": [
    {
      "source": "/api/search/v6",
      "destination": "/search-api/overview"
    },
    {
      "source": "/api/search/v6/",
      "destination": "/search-api/overview"
    },
    {
      "source": "/api/search/v5",
      "destination": "/search-api/overview"
    },
    {
      "source": "/api/search/v5/",
      "destination": "/search-api/overview"
    },
    {
      "source": "/api/management/v2",
      "destination": "/management-api/overview"
    },
    {
      "source": "/api/management/v2/",
      "destination": "/management-api/overview"
    },
    {
      "source": "/api/stats/v2",
      "destination": "/stats-api/overview"
    },
    {
      "source": "/api/stats/v2/",
      "destination": "/stats-api/overview"
    },
    {
      "source": "/api/management/v2/stats",
      "destination": "/stats-api/overview"
    },
    {
      "source": "/api/management/v2/stats/",
      "destination": "/stats-api/overview"
    },
    {
      "source": "/api/recommendations",
      "destination": "/recommendations-api/overview"
    },
    {
      "source": "/api/recommendations/",
      "destination": "/recommendations-api/overview"
    },
    {
      "source": "/api/category-merchandising",
      "destination": "/category-merchandising/overview"
    },
    {
      "source": "/api/category-merchandising/",
      "destination": "/category-merchandising/overview"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "introduction/quickstart",
              "introduction/authentication",
              "introduction/errors"
            ]
          }
        ]
      },
      {
        "tab": "Search API",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "search-api/overview"
            ]
          },
          {
            "group": "Search ",
            "openapi": "openapi/search-v6.yaml",
            "pages": [
              "GET /6/{hashid}/_search",
              "POST /6/{hashid}/_search",
              "GET /6/{hashid}/_suggest",
              "POST /6/{hashid}/_image_search",
              "GET /6/{hashid}/_visually_similar"
            ]
          },
          {
            "group": "Session & Events",
            "openapi": "openapi/search-v6.yaml",
            "pages": [
              "PUT /6/{hashid}/stats/init",
              "PUT /6/{hashid}/stats/click",
              "PUT /6/{hashid}/stats/cart/{session_id}",
              "PUT /6/{hashid}/stats/redirect",
              "PUT /6/{hashid}/stats/image"
            ]
          }
        ]
      },
      {
        "tab": "Management API",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "management-api/overview"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "openapi/management-v2.yaml",
            "pages": []
          }
        ]
      },
      {
        "tab": "Stats API",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "stats-api/overview"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "openapi/stats-v2.yaml",
            "pages": []
          }
        ]
      },
      {
        "tab": "Recommendations API",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "recommendations-api/overview"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "openapi/recommendations-v1.yaml",
            "pages": [
              "POST /api/widget/{widget_id}"
            ]
          }
        ]
      },
      {
        "tab": "Category Merchandising API",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "category-merchandising/overview"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "openapi/category-merchandising-v1.yaml",
            "pages": [
              "GET /category_merchandising/{hashid}"
            ]
          }
        ]
      }
    ]
  }
}
